@startuml db_schema
!theme plain
skinparam linetype ortho
skinparam roundcorner 8
skinparam shadowing false
skinparam defaultFontName Helvetica
skinparam defaultFontSize 12

skinparam class {
    BackgroundColor White
    BorderColor #444444
    HeaderBackgroundColor #2C6E9E
    HeaderFontColor White
    HeaderFontStyle bold
}

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

' ─────────────────────────────────────────────
'  ENUMS
' ─────────────────────────────────────────────

enum Role <<enum>> {
    INVESTIGADOR
    ADMIN
}

enum Day <<enum>> {
    DAY1
    DAY2
}

enum JobStatus <<enum>> {
    QUEUED
    RUNNING
    DONE
    FAILED
}

enum PipelineStage <<enum>> {
    PREPROCESSING
    ROI_DETECTION
    TRACKING
    CLASSIFICATION
    DONE
}

enum ReportFormat <<enum>> {
    PDF
    CSV
}

enum NotificationType <<enum>> {
    ANALYSIS_DONE
    ANALYSIS_FAILED
    VIDEO_EXPIRING
    VIDEO_DELETED
}

' ─────────────────────────────────────────────
'  TABLAS
' ─────────────────────────────────────────────

entity "users" as users {
    * id : INTEGER <<PK>>
    --
    * email : VARCHAR(255) <<UNIQUE>>
    * password_hash : VARCHAR(255)
    * name : VARCHAR(120)
    * role : Role
    * is_active : BOOLEAN = true
    * must_change_password : BOOLEAN = false
    * created_at : DATETIME
    last_login : DATETIME
}

entity "experiments" as experiments {
    * id : INTEGER <<PK>>
    --
    * user_id : INTEGER <<FK→users>>
    * created_at : DATETIME
    * name : VARCHAR(120)
    experiment_date : DATETIME
    treatment : VARCHAR(255)
    species : VARCHAR(120)
    * layout : VARCHAR(20) = 'auto'
    notes : TEXT
}

note right of experiments
  layout: parámetro de disposición espacial
  del pipeline ('auto', '1x3', '1x4', '2x2')
  Reemplaza num_animals — captura geometría
  real, no solo conteo.
end note

entity "subjects" as subjects {
    * id : INTEGER <<PK>>
    --
    * experiment_id : INTEGER <<FK→experiments>>
    * rat_idx : INTEGER
    label : VARCHAR(50)
    --
    <<UNIQUE (experiment_id, rat_idx)>>
}

note right of subjects
  Identidad persistente del animal.
  rat_idx = posición física en el encuadre.
  Permite trazar la misma rata entre
  DAY1 y DAY2 sin depender del job_id.
end note

entity "videos" as videos {
    * id : INTEGER <<PK>>
    --
    * experiment_id : INTEGER <<FK→experiments>>
    * created_at : DATETIME
    * day : Day
    * filename : VARCHAR(255)
    * path : VARCHAR(512)
    duration_s : FLOAT
    deletion_date : DATETIME
    --
    <<UNIQUE (experiment_id, day)>>
    <<CHECK: deletion_date > created_at>>
}

entity "rois" as rois {
    * id : INTEGER <<PK>>
    --
    * video_id : INTEGER <<FK→videos>>
    * rat_idx : INTEGER
    * x : INTEGER
    * y : INTEGER
    * w : INTEGER
    * h : INTEGER
    --
    <<UNIQUE (video_id, rat_idx)>>
}

note right of rois
  Geometría del cilindro detectado.
  Normalizado desde roi_json (TEXT) y
  animals.roi_* a tabla propia para
  permitir consultas SQL directas.
end note

entity "analysis_configs" as analysis_configs {
    * id : INTEGER <<PK>>
    --
    * created_at : DATETIME
    * model_name : VARCHAR(120)
    * pipeline_version : VARCHAR(30)
    * layout : VARCHAR(20)
    * conf_threshold : FLOAT
    * skip_seconds : FLOAT = 0.0
    * immobile_thr : FLOAT = 6.5
    * disp_thr : FLOAT = 8.0
    * pos_std_thr : FLOAT = 20.0
    * climb_aspect_thr : FLOAT = 1.6
}

note right of analysis_configs
  Reproducibilidad: parámetros exactos
  de cada ejecución del pipeline.
  Citables en publicaciones.
end note

entity "jobs" as jobs {
    * id : INTEGER <<PK>>
    --
    * video_id : INTEGER <<FK→videos>>
    config_id : INTEGER <<FK→analysis_configs>>
    * created_at : DATETIME
    started_at : DATETIME
    finished_at : DATETIME
    * status : JobStatus = QUEUED
    stage : PipelineStage
    * progress_pct : INTEGER = 0
    error : TEXT
}

entity "animals" as animals {
    * id : INTEGER <<PK>>
    --
    * job_id : INTEGER <<FK→jobs>>
    subject_id : INTEGER <<FK→subjects>>
    * rat_idx : INTEGER
    --
    <<UNIQUE (job_id, rat_idx)>>
}

entity "behavior_results" as behavior_results {
    * id : INTEGER <<PK>>
    --
    * animal_id : INTEGER <<FK→animals>>
    * swim_s : FLOAT = 0.0
    * immobile_s : FLOAT = 0.0
    * escape_s : FLOAT = 0.0
    --
    <<CHECK: swim_s >= 0 AND immobile_s >= 0>>
    <<        AND escape_s >= 0>>
}

entity "behavior_per_minute" as behavior_per_minute {
    * id : INTEGER <<PK>>
    --
    * animal_id : INTEGER <<FK→animals>>
    * minute : INTEGER
    * swim_s : FLOAT = 0.0
    * immobile_s : FLOAT = 0.0
    * escape_s : FLOAT = 0.0
    --
    <<UNIQUE (animal_id, minute)>>
}

note right of behavior_per_minute
  Reemplaza behavior_results.per_minute_json.
  Tabla normalizada: consultable con SQL,
  validable con constraints (RF-19).
end note

entity "reports" as reports {
    * id : INTEGER <<PK>>
    --
    * experiment_id : INTEGER <<FK→experiments>>
    * created_at : DATETIME
    * format : ReportFormat
    * path : VARCHAR(512)
}

entity "notifications" as notifications {
    * id : INTEGER <<PK>>
    --
    * user_id : INTEGER <<FK→users>>
    * created_at : DATETIME
    * type : NotificationType
    * message : TEXT
    * is_read : BOOLEAN = false
    experiment_id : INTEGER <<FK→experiments>>
}

' ─────────────────────────────────────────────
'  RELACIONES
' ─────────────────────────────────────────────

users               ||--o{ experiments         : "user_id"
users               ||--o{ notifications       : "user_id"

experiments         ||--o{ videos              : "experiment_id"
experiments         ||--o{ subjects            : "experiment_id"
experiments         ||--o{ reports             : "experiment_id"
experiments         |o--o{ notifications       : "experiment_id"

videos              ||--o{ jobs                : "video_id"
videos              ||--o{ rois                : "video_id"

analysis_configs    ||--o{ jobs                : "config_id"

jobs                ||--o{ animals             : "job_id"

subjects            ||--o{ animals             : "subject_id"

animals             ||--o{ behavior_results    : "animal_id"
animals             ||--o{ behavior_per_minute : "animal_id"

' ─────────────────────────────────────────────
'  NOTAS EXPLICATIVAS
' ─────────────────────────────────────────────

note bottom of videos
  deletion_date = finished_at + 30 días
  CHECK: deletion_date > created_at
  (RN-05, RF-24, RNF-08)
  UNIQUE (experiment_id, day):
  máx 1 video por día (RN-03)
end note

note bottom of jobs
  stage + progress_pct
  alimentan la barra de progreso
  en tiempo real (RF-15)
  config_id → reproducibilidad del análisis
end note

note right of users
  password_hash: bcrypt con sal
  (RNF-05)
  must_change_password: contraseña
  temporal del Admin (RF-05)
end note

@enduml
